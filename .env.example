# Copy to .env and fill in. The /analyze demo works WITHOUT any keys in development.

# --- Runtime ---
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO

# --- Security (enforced in production) ---
# Comma-separated keys clients must send as "Authorization: Bearer <key>"
# or "X-API-Key: <key>". Leave empty in dev to disable auth.
API_KEYS=
# Comma-separated allowed browser origins. Wildcard is ignored in production.
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=120

# --- AI content generation (optional; Anthropic preferred when both set) ---
# Get a key at https://console.anthropic.com . With a key set, the app generates
# real content (outreach, research, posts, scripts) instead of templates.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Step 2: lead data (stubs return mock data until you add these) ---
APOLLO_API_KEY=
ZOOMINFO_API_KEY=
CLAY_API_KEY=

# --- Step 3: outreach sending (pick ONE provider; needs warmed mailboxes) ---
# Create a campaign in the provider whose sequence references {{subject}}/{{body}}.
INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=
SMARTLEAD_API_KEY=
SMARTLEAD_CAMPAIGN_ID=

# --- Step 4: dialer (places real calls when set) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=          # e.g. +15555550123 (a Twilio number you own)
TWILIO_TWIML_URL=            # public TwiML URL controlling the call on answer
DEEPGRAM_API_KEY=            # for the (follow-up) live teleprompter

# --- Infra ---
# Local dev with zero setup: sqlite:///./dev.db
# Production: postgresql://user:pass@host:5432/outflow
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/outflow
REDIS_URL=redis://localhost:6379/0
